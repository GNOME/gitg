<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="spin_button_right_margin_adjustment">
    <property name="lower">1</property>
    <property name="upper">160</property>
    <property name="value">72</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
  <object class="GtkAdjustment" id="spin_button_max_num_commit_messages_adjustment">
    <property name="upper">100</property>
    <property name="value">10</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
  <object class="GtkAdjustment" id="spin_button_max_num_days_commit_messages_adjustment">
    <property name="upper">365</property>
    <property name="value">30</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
  <object class="GtkAdjustment" id="spin_button_subject_margin_adjustment">
    <property name="upper">100</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
  <template class="GitgPreferencesCommit" parent="GtkGrid">
    <property name="hexpand">1</property>
    <property name="vexpand">1</property>
    <property name="margin-top">12</property>
    <property name="margin-bottom">12</property>
    <property name="margin-start">12</property>
    <property name="margin-end">12</property>
    <property name="row_spacing">18</property>
    <property name="column_spacing">18</property>
    <child>
      <object class="GtkGrid" id="grid">
        <property name="hexpand">1</property>
        <property name="row_spacing">6</property>
        <child>
          <object class="GtkGrid" id="grid1">
            <property name="row_spacing">6</property>
            <property name="margin_start">12</property>
            <child>
              <object class="GtkCheckButton" id="check_button_show_markup">
                <property name="label" translatable="1">Show markup</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="grid_show_markup">
                <property name="row_spacing">6</property>
                <property name="column_spacing">6</property>
                <child>
                  <object class="GtkCheckButton" id="check_button_show_subject_margin">
                    <property name="label" translatable="1">Display _subject margin at column:</property>
                    <property name="focusable">1</property>
                    <property name="use_underline">1</property>
                    <property name="halign">start</property>
                    <property name="active">1</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkGrid" id="spin_button_subject_margin_grid">
                    <child>
                      <object class="GtkSpinButton" id="spin_button_subject_margin">
                        <property name="focusable">1</property>
                        <property name="adjustment">spin_button_subject_margin_adjustment</property>
                        <property name="climb_rate">1</property>
                        <property name="snap_to_ticks">1</property>
                        <property name="numeric">1</property>
                        <property name="width_chars">3</property>
                        <property name="max_width_chars">3</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkCheckButton" id="check_button_show_right_margin">
                    <property name="label" translatable="1">Display right _margin at column:</property>
                    <property name="focusable">1</property>
                    <property name="use_underline">1</property>
                    <property name="halign">start</property>
                    <property name="active">1</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkGrid" id="spin_button_right_margin_grid">
                    <child>
                      <object class="GtkSpinButton" id="spin_button_right_margin">
                        <property name="focusable">1</property>
                        <property name="adjustment">spin_button_right_margin_adjustment</property>
                        <property name="climb_rate">1</property>
                        <property name="snap_to_ticks">1</property>
                        <property name="numeric">1</property>
                        <property name="width_chars">3</property>
                        <property name="max_width_chars">3</property>
                        <layout>
                          <property name="column">0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="1">Maximum number of messages:</property>
                    <property name="halign">start</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">2</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_button_max_num_commit_messages">
                    <property name="focusable">1</property>
                    <property name="adjustment">spin_button_max_num_commit_messages_adjustment</property>
                    <property name="climb_rate">1</property>
                    <property name="snap_to_ticks">1</property>
                    <property name="numeric">1</property>
                    <property name="width_chars">3</property>
                    <property name="max_width_chars">3</property>
                    <property name="tooltip_text" translatable="1">Maximum number of messages to keep for commit message history</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">2</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="1">Maximum number of days:</property>
                    <property name="halign">start</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">3</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkSpinButton" id="spin_button_max_num_days_commit_messages">
                    <property name="focusable">1</property>
                    <property name="adjustment">spin_button_max_num_days_commit_messages_adjustment</property>
                    <property name="climb_rate">1</property>
                    <property name="snap_to_ticks">1</property>
                    <property name="numeric">1</property>
                    <property name="width_chars">3</property>
                    <property name="max_width_chars">3</property>
                    <property name="tooltip_text" translatable="1">Maximum number of days to keep for commit message history</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">3</property>
                    </layout>
                  </object>
                </child>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="grid8">
                <property name="column_spacing">12</property>
                <child>
                  <object class="GtkLabel" id="label7">
                    <property name="label" translatable="1">Language:</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GspellLanguageChooserButton" id="spell_language_button">
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <layout>
                  <property name="column">0</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="enable_spell_checking">
                <property name="label" translatable="1">Enable spell checking</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">3</property>
                </layout>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">1</property>
              <property name="row-span">2</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="label1">
            <property name="halign">start</property>
            <property name="label" translatable="1">Commit Message</property>
            <attributes>
              <attribute name="weight" value="bold"></attribute>
            </attributes>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <layout>
          <property name="column">0</property>
          <property name="row">0</property>
        </layout>
      </object>
    </child>
    <child>
      <object class="GtkGrid" id="grid_datetime">
        <property name="hexpand">1</property>
        <property name="row_spacing">6</property>
        <child>
          <object class="GtkLabel" id="datetime_preference_top_label">
            <property name="halign">start</property>
            <property name="label" translatable="1">Datetime format</property>
            <attributes>
              <attribute name="weight" value="bold"></attribute>
            </attributes>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkGrid" id="grid_prefered_datetime_default">
            <child>
              <object class="GtkComboBoxText" id="combobox_predefined_datetime">
                <property name="active">0</property>
                <property name="active_id">0</property>
                <items>
                  <item id="%Y-%m">%Y-%m</item>
                  <item id="%Y-%m-%d">%Y-%m-%d</item>
                  <item id="%Y-%m-%dT%R%z">%Y-%m-%dT%R%z</item>
                  <item id="%Y-%m-%dT%T%z">%Y-%m-%dT%T%z</item>
                  <item id="%Y">%Y</item>
                  <item id="%Y-%d-%m">%Y-%d-%m</item>
                  <item id="%Y-%d-%mT%R%z">%Y-%d-%mT%R%z</item>
                  <item id="%Y-%d-%mT%T%z">%Y-%d-%mT%T%z</item>
                </items>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="radiobutton_predefined_datetime">
                <property name="label" translatable="1">Predefined:</property>
                <property name="focusable">1</property>
                <property name="active">1</property>
                <property name="group">radiobutton_custom_datetime</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkGrid">
            <child>
              <object class="GtkCheckButton" id="radiobutton_custom_datetime">
                <property name="label" translatable="1">Custom:</property>
                <property name="focusable">1</property>
                <property name="group">radiobutton_predefined_datetime</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkEntry" id="custom_datetime">
                <property name="focusable">1</property>
                <property name="secondary-icon-name">gtk-help</property>
                <property name="secondary_icon_sensitive">0</property>
                <property name="secondary_icon_tooltip_markup" translatable="1">Check in vala documentation for datetime to write your own format.</property>
                <layout>
                  <property name="column">1</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">2</property>
            </layout>
          </object>
        </child>
        <layout>
          <property name="column">0</property>
          <property name="row">1</property>
        </layout>
      </object>
    </child>
  </template>
</interface>
