<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkAdjustment" id="adjustment_collapse">
    <property name="upper">5</property>
    <property name="value">2</property>
    <property name="step_increment">1</property>
    <property name="page_increment">1</property>
    <property name="page_size">1</property>
  </object>
  <template class="GitgPreferencesHistory" parent="GtkGrid">
    <property name="hexpand">1</property>
    <property name="vexpand">1</property>
    <property name="margin-top">12</property>
    <property name="margin-bottom">12</property>
    <property name="margin-start">12</property>
    <property name="margin-end">12</property>
    <property name="row_spacing">18</property>
    <property name="column_spacing">18</property>
    <child>
      <object class="GtkGrid" id="grid2">
        <property name="hexpand">1</property>
        <property name="row_spacing">6</property>
        <child>
          <object class="GtkLabel" id="label2">
            <property name="halign">start</property>
            <property name="label" translatable="1">Default selection</property>
            <attributes>
              <attribute name="weight" value="bold"></attribute>
            </attributes>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkGrid" id="grid1">
            <property name="margin_start">12</property>
            <property name="hexpand">1</property>
            <property name="vexpand">1</property>
            <child>
              <object class="GtkCheckButton" id="select_current_branch">
                <property name="label" translatable="1">Current branch</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="select_all_branches">
                <property name="label" translatable="1">All branches</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <property name="group">select_current_branch</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="select_all_commits">
                <property name="label" translatable="1">All commits</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <property name="active">1</property>
                <property name="group">select_current_branch</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="label3">
            <property name="halign">start</property>
            <property name="label" translatable="1">References</property>
            <property name="margin_top">12</property>
            <attributes>
              <attribute name="weight" value="bold"></attribute>
            </attributes>
            <layout>
              <property name="column">0</property>
              <property name="row">2</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="sort_references_by_activity">
            <property name="label" translatable="1">Sort references in the sidebar by latest activity</property>
            <property name="use_action_appearance">False</property>
            <property name="focusable">1</property>
            <property name="halign">start</property>
            <property name="margin_start">12</property>
            <layout>
              <property name="column">0</property>
              <property name="row">3</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="show_upstream_with_branch">
            <property name="label" translatable="1">Show upstream (remote) branch when selecting a local branch</property>
            <property name="use_action_appearance">False</property>
            <property name="focusable">1</property>
            <property name="halign">start</property>
            <property name="margin_start">12</property>
            <layout>
              <property name="column">0</property>
              <property name="row">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkCheckButton" id="filter_unknown_refs">
            <property name="label" translatable="1">Filter unknown refs</property>
            <property name="use_action_appearance">False</property>
            <property name="focusable">1</property>
            <property name="halign">start</property>
            <property name="margin_start">12</property>
            <layout>
              <property name="column">0</property>
              <property name="row">5</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="label1">
            <property name="halign">start</property>
            <property name="label" translatable="1">Commits</property>
            <property name="margin_top">12</property>
            <attributes>
              <attribute name="weight" value="bold"></attribute>
            </attributes>
            <layout>
              <property name="column">0</property>
              <property name="row">6</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkGrid" id="grid4">
            <property name="margin_start">12</property>
            <property name="hexpand">1</property>
            <property name="vexpand">1</property>
            <child>
              <object class="GtkCheckButton" id="collapse_inactive_lanes_enabled">
                <property name="label" translatable="1">Collapse inactive lanes</property>
                <property name="use_action_appearance">False</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="grid5">
                <property name="margin_start">12</property>
                <property name="margin_top">6</property>
                <property name="margin_bottom">12</property>
                <property name="hexpand">1</property>
                <child>
                  <object class="GtkScale" id="collapse_inactive_lanes">
                    <property name="focusable">1</property>
                    <property name="hexpand">1</property>
                    <property name="adjustment">adjustment_collapse</property>
                    <property name="digits">0</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                      <property name="column-span">2</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="label4">
                    <property name="halign">start</property>
                    <property name="label" translatable="1">Early</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="label5">
                    <property name="halign">end</property>
                    <property name="label" translatable="1">Late</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="topological_order">
                <property name="label" translatable="1">Show history in topological order</property>
                <property name="use_action_appearance">False</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">2</property>
                </layout>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="mainline_head">
                <property name="label" translatable="1">Preserve mainline for currently checked out branch</property>
                <property name="use_action_appearance">False</property>
                <property name="focusable">1</property>
                <property name="halign">start</property>
                <layout>
                  <property name="column">0</property>
                  <property name="row">3</property>
                </layout>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">7</property>
            </layout>
          </object>
        </child>
        <layout>
          <property name="column">0</property>
          <property name="row">0</property>
        </layout>
      </object>
    </child>
  </template>
</interface>
