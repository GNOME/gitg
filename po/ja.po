#: data/org.gnome.gitg.appdata.xml.in.in:5 gitg/gitg.vala:39
#: gitg/resources/ui/gitg-window.ui:8
msgid "gitg"
msgstr "gitg"

#: data/org.gnome.gitg.appdata.xml.in.in:9
msgid "Graphical user interface for git"
msgstr "gitのグラフィカルユーザーインターフェース"

#: data/org.gnome.gitg.appdata.xml.in.in:11
msgid ""
"gitg is a graphical user interface for git. It aims at being a small, fast "
"and convenient tool to visualize the history of git repositories. Besides "
"visualization, gitg also provides several utilities to manage your "
"repository and commit your work."
msgstr ""
"gitgはGUIのあるgitです。このプロジェクトはgitgが小さくて、早くそしてgitのリポ"
"ジトリの履歴を可視化する便利なツールになることを目指しています。可視化につい"
"ていえば、gitgはまたあなたのリポジトリを管理し、あなたの作品をコミットする"
"ユーティリティをいくつか提供します。"

#: data/org.gnome.gitg.appdata.xml.in.in:17
msgid "Goals:"
msgstr "ゴール:"

#: data/org.gnome.gitg.appdata.xml.in.in:19
msgid "Browse local git repositories"
msgstr "ローカルのgitリポジトリをブラウズする"

#: data/org.gnome.gitg.appdata.xml.in.in:20
msgid "Clone local and remote git repositories"
msgstr "ローカルまたはリモートのgitリポジトリにクローンする"

#: data/org.gnome.gitg.appdata.xml.in.in:21
msgid "Commit files"
msgstr "ファイルをコミットする"

#: data/org.gnome.gitg.appdata.xml.in.in:22
msgid "Retrieve patch from a commit"
msgstr "コミットからパッチを取得する"

#: data/org.gnome.gitg.appdata.xml.in.in:32
msgid "Browse repository history"
msgstr "リポジトリの履歴を閲覧する"

#: data/org.gnome.gitg.appdata.xml.in.in:36
msgid "Staging area to compose your commit"
msgstr "あなたのコミットからステージングエリアを構成する"

#: data/org.gnome.gitg.appdata.xml.in.in:40
msgid "Commit staged changes"
msgstr "ステージ登録済みの変更をコミットする"

#: data/org.gnome.gitg.appdata.xml.in.in:44
msgid "Overview of recently used repositories"
msgstr "最近使用したリポジトリの概要"

#: data/org.gnome.gitg.appdata.xml.in.in:105
msgid "The GNOME Project"
msgstr "The GNOME Project"

#: data/org.gnome.gitg.desktop.in.in:3
msgid "@binary@"
msgstr "@binary@"

#: data/org.gnome.gitg.desktop.in.in:4
msgid "Git repository browser"
msgstr "Git リポジトリブラウザー"

#: data/org.gnome.gitg.gschema.xml.in:28
msgid "Default Clone Directory"
msgstr "デフォルトのクローンディレクトリ"

#: data/org.gnome.gitg.gschema.xml.in:29
msgid ""
"The default directory in which new repositories should be suggested to be "
"cloned."
msgstr "新しいリポジトリをクローンするときに提案するデフォルトのディレクトリ。"

#: data/org.gnome.gitg.gschema.xml.in:38
msgid "Orientation of the main interface (vertical or horizontal)"
msgstr "メインインターフェースの方向(垂直または水平)"

#: data/org.gnome.gitg.gschema.xml.in:39
msgid "Setting that sets the orientation of the main interface."
msgstr "メインのインターフェースの方向を設定します。"

#: data/org.gnome.gitg.gschema.xml.in:45
msgid "Default Activity"
msgstr "デフォルトアクティビティ"

#: data/org.gnome.gitg.gschema.xml.in:46
msgid "The activity which gitg activates by default when first launched."
msgstr "gitgが起動したときに行うデフォルトのアクティビティ。"

#: data/org.gnome.gitg.gschema.xml.in:52
msgid "Use Default Font"
msgstr "デフォルトのフォントの使用"

#: data/org.gnome.gitg.gschema.xml.in:53
msgid ""
"Whether to use the system’s default fixed width font for widget's text "
"instead of a font specific. If this option is turned off, then the font "
"named in the “Editor Font” option will be used instead of the system font."
msgstr ""
"特定のフォントの代りに、テキストウィジェットで使用するシステムのデフォルトの"
"固定幅フォントを使用する。このオプションをオフにした場合、システムフォントの"
"代りに”エディターフォント”で指定したフォントを使用する。"

#. Translators: This is a GSettings default value. Do NOT change or localize the quotation marks!
#: data/org.gnome.gitg.gschema.xml.in:57
msgid "'Monospace 12'"
msgstr "‘Monospace 12’"

#: data/org.gnome.gitg.gschema.xml.in:58
msgid "Editor Font"
msgstr "エディターフォント"

#: data/org.gnome.gitg.gschema.xml.in:59
msgid ""
"A custom font that will be used for the text widgets. This will only take "
"effect if the “Use Default Font” option is turned off."
msgstr ""
"テキストウィジェットで使用するカスタムフォント。デフォルトのフォントを使用の"
"オプションが無効のときにのみ有効です。"

#: data/org.gnome.gitg.gschema.xml.in:63
msgid "Use Gravatar"
msgstr "Gravatarの使用"

#: data/org.gnome.gitg.gschema.xml.in:64
msgid "Enable the use of gravatar to display user avatars."
msgstr "gravatarを有効にしてユーザーのアバターとして表示します。"

#: data/org.gnome.gitg.gschema.xml.in:70
msgid "Enable Monitoring"
msgstr "モニタリングを有効にする"

#: data/org.gnome.gitg.gschema.xml.in:71
#: gitg/resources/ui/gitg-preferences-interface.ui:188
msgid "Automatically update when external changes to .git are detected"
msgstr ".gitへの外部からの変更が検出されたときの自動更新"

#: data/org.gnome.gitg.gschema.xml.in:77
msgid "Enable Diff Highlighting"
msgstr "差分ハイライトを有効にする"

#: data/org.gnome.gitg.gschema.xml.in:78
msgid ""
"Setting that determines whether to enable syntax highlighting in diff views."
msgstr "差分画面でのシンタックスハイライトを有効にするかどうかを設定します。"

#: data/org.gnome.gitg.gschema.xml.in:85
msgid "Color scheme to use for syntax highlighting"
msgstr "シンタックスハイライトにカラスキームを使用する"

#: data/org.gnome.gitg.gschema.xml.in:86
msgid "Used by GtkSourceView to determine colors for syntax highlighting"
msgstr "シンタックスハイライトの色を決定するためにGtkSourceViewを使用"

#: data/org.gnome.gitg.gschema.xml.in:92
msgid "When to Collapse Inactive Lanes"
msgstr "非アクティブなレーンを隠す条件"

#: data/org.gnome.gitg.gschema.xml.in:93
msgid ""
"Setting that indicates when an inactive lane should be collapsed. Valid "
"values are 0 — 4, where 0 indicates “early” and 4 indicates “late”."
msgstr ""
"非アクティブなレーンを隠すときの設定。0~4の値で指定する。0は早い、4は遅いを意"
"味する。"

#: data/org.gnome.gitg.gschema.xml.in:100
msgid ""
"Setting that indicates whether to collapse history lanes which do not show "
"activity. Enabling this can provide a cleaner history view when there is a "
"lot of parallel development. See collapse-inactive-lanes to control when "
"lanes should be collapsed."
msgstr ""
"アクティビティが表示されていない履歴レーンを隠すかどうかを指定します。並行し"
"た開発が多い場合、このオプションを有効にすると履歴の表示がすっきりします。"
"レーンの非表示については collapse-inactive-lanesを参照してください。"

#: data/org.gnome.gitg.gschema.xml.in:109
msgid "Show History in Topological Order"
msgstr "トポロジカルの順に履歴を表示"

#: data/org.gnome.gitg.gschema.xml.in:110
msgid ""
"Setting that indicates whether to show the history in topological order."
msgstr "トポロジカルの順に履歴を表示するかどうかを設定します。"

#: data/org.gnome.gitg.gschema.xml.in:116
msgid "Show Stashed Changes"
msgstr "スタッシュの変更を履歴に表示する"

#: data/org.gnome.gitg.gschema.xml.in:117
msgid ""
"Setting that indicates whether to show items for the stash in the history."
msgstr "履歴上にスタッシュのアイテムを表示するかどうか。"

#: data/org.gnome.gitg.gschema.xml.in:124
msgid "Show Staged Changes"
msgstr "ステージ登録済みの変更を履歴に表示"

#: data/org.gnome.gitg.gschema.xml.in:125
msgid ""
"Setting that indicates whether to show a virtual item for the currently "
"staged changes in the history."
msgstr ""
"履歴上に現在のステージ登録済みの変更を示すバーチャルなアイテムを表示するかど"
"うか。"

#: data/org.gnome.gitg.gschema.xml.in:132
msgid "Show Unstaged Changes"
msgstr "ステージ未登録の変更を履歴に表示"

#: data/org.gnome.gitg.gschema.xml.in:133
msgid ""
"Setting that indicates whether to show a virtual item for the currently "
"unstaged changes in the history."
msgstr ""
"履歴にステージに登録されていない現在の変更を示すバーチャルなアイテムを表示す"
"るかどうか。"

#: data/org.gnome.gitg.gschema.xml.in:140
msgid "Mainline Head"
msgstr "メインラインのヘッド"

#: data/org.gnome.gitg.gschema.xml.in:141
msgid ""
"Setting that indicates whether to always preserve a mainline in the history "
"for the current HEAD."
msgstr "現在のHEADの履歴に常にメインラインを残すかどうか。"

#: data/org.gnome.gitg.gschema.xml.in:148
msgid "Default selection of the history activity"
msgstr "履歴アクテイビティのデフォルトの選択"

#: data/org.gnome.gitg.gschema.xml.in:149
msgid ""
"Setting that determines the default selection on startup of the history "
"activity."
msgstr "起動時の履歴アクテイビティのデフォルトの選択を設定します。"

#: data/org.gnome.gitg.gschema.xml.in:155
msgid "Reference Sort Order"
msgstr "参照のソートの順番"

#: data/org.gnome.gitg.gschema.xml.in:156
msgid "The order by which references in the history sidebar should be sorted."
msgstr "履歴のサイドバーで参照を並べる順番。"

#: data/org.gnome.gitg.gschema.xml.in:162
msgid "Show Upstream With Branch"
msgstr "ブランチありでアップストリームを表示"

#: data/org.gnome.gitg.gschema.xml.in:163
msgid ""
"Determines whether to also show the upstream (remote) tracking branch when "
"selecting a local branch in the history view."
msgstr ""
"履歴画面でローカルブランチを選択したときに、アップストリーム(リモート)の追跡"
"しているブランチも表示するかどうか。"

#: data/org.gnome.gitg.gschema.xml.in:172
msgid "Switch to the new branch on creation"
msgstr "ブランチの作成時にその作成したブランチに切り替える"

#: data/org.gnome.gitg.gschema.xml.in:173
msgid ""
"Setting that controls whether the newly created branch is checked out "
"automatically."
msgstr ""
"新規に作成したブランチへ自動的にチェックアウトするかどうかを制御します。"

#: data/org.gnome.gitg.gschema.xml.in:188
msgid "Show Right Margin in Commit Message View"
msgstr "コミットメッセージ画面で右マージンを表示する"

#: data/org.gnome.gitg.gschema.xml.in:189
msgid ""
"Show a right margin indicator in the commit message view. This can be used "
"to easily see where to break the commit message at a particular column."
msgstr ""
"コミットメッセージ画面で右マージンインディケーターを表示します。特定のカラム"
"でコミットメッセージが改行している箇所が簡単にわかります。"

#: data/org.gnome.gitg.gschema.xml.in:197
msgid "Column at Which Right Margin is Shown"
msgstr "右マージンでカラムを表示"

#: data/org.gnome.gitg.gschema.xml.in:198
msgid ""
"The column at which the right margin is shown if the show-right-margin "
"preference is set to TRUE."
msgstr ""
"右マージンの箇所にカラムを表示します。ただし右マージンを表示の設定がTRUEのと"
"きのみ有効です。"

#: data/org.gnome.gitg.gschema.xml.in:205
msgid "Show Subject Margin in Commit Message View"
msgstr "コミットメッセージ画面のサブジェクトマージンの表示"

#: data/org.gnome.gitg.gschema.xml.in:206
msgid ""
"Highlight the subject text of the commit message when it passes the margin "
"specified by subject-margin-position."
msgstr ""
"subject-margin-positionによって指定されたマージンが渡されたときの、コミット"
"メッセージのサブジェクト文のハイライト。"

#: data/org.gnome.gitg.gschema.xml.in:213
msgid "Column at Which Subject Margin is Shown"
msgstr "サブジェクトマージンのカラムを表示"

#: data/org.gnome.gitg.gschema.xml.in:214
msgid ""
"The column at which the subject margin is shown if the show-subject-margin "
"preference is set to TRUE."
msgstr ""
"show-subject-margin設定項目がTRUEの場合にサブジェクトマージンのカラムを表示。"

#: data/org.gnome.gitg.gschema.xml.in:221
msgid "Enable Spell Checking"
msgstr "スペルチェックを有効にする"

#: data/org.gnome.gitg.gschema.xml.in:222
msgid ""
"Setting which determines whether or not spell checking is enabled when "
"writing a commit message."
msgstr "コミットメッセージの入力時にスペルチェックを有効にするかどうか。"

#: data/org.gnome.gitg.gschema.xml.in:229
msgid "Spell Checking Language"
msgstr "スペルチェックの言語"

#: data/org.gnome.gitg.gschema.xml.in:230
msgid ""
"The language to use when spell checking is enabled for writing a commit "
"message."
msgstr ""
"コミットメッセージ入力時のスペルチェックを有効にした場合のスペルチェック対象"
"の言語。"

#: data/org.gnome.gitg.gschema.xml.in:237
msgid "Maximum number of previous commit messages"
msgstr "以前のコミットメッセージの最大数"

#: data/org.gnome.gitg.gschema.xml.in:238
msgid ""
"Maximum number of previous commit messages to store for commit message "
"history."
msgstr "コミットメッセージの履歴で保存する、以前のコミットメッセージの最大数。"

#: data/org.gnome.gitg.gschema.xml.in:242
msgid "Maximum number of days to store previous commit messages"
msgstr "以前のコミットメッセージを保存する最大日数"

#: data/org.gnome.gitg.gschema.xml.in:243
msgid ""
"Maximum number of days to store previous commit messages for commit message "
"history."
msgstr ""
"コミットメッセージの履歴のために保存する以前のコミットメッセージの最大日数。"

#: data/org.gnome.gitg.gschema.xml.in:249
msgid "Use patience algorithm to show diffs"
msgstr "差分の表示に patience アルゴリズムを採用"

#: data/org.gnome.gitg.gschema.xml.in:250
msgid "Setting to use patience algorithm to show diffs of a commit."
msgstr "コミットの差分を表示する際に patience アルゴリズムを使用する設定。"

#: data/org.gnome.gitg.gschema.xml.in:256
msgid "Ignore Whitespace Changes"
msgstr "変更中の空白文字を無視"

#: data/org.gnome.gitg.gschema.xml.in:257
msgid ""
"Setting that indicates whether to ignore whitespace changes when showing the "
"diff of a commit."
msgstr ""
"コミットの差分を表示する際に変更に含まれる空白文字を無視するように設定。"

#: data/org.gnome.gitg.gschema.xml.in:264
msgid "Show Changes Inline"
msgstr "変更をインライン表示"

#: data/org.gnome.gitg.gschema.xml.in:265
msgid ""
"Setting that indicates whether changes within lines should be shown inline."
msgstr "変更をインラインで表示するかどうか。"

#: data/org.gnome.gitg.gschema.xml.in:272
msgid "Wrap"
msgstr "折り返し"

#: data/org.gnome.gitg.gschema.xml.in:273
msgid "Wrap lines."
msgstr "行を折り返す。"

#: data/org.gnome.gitg.gschema.xml.in:279
#: data/org.gnome.gitg.gschema.xml.in:297
msgid "Number of Before/After Context Lines"
msgstr "コンテキスト行の前後の行数"

#: data/org.gnome.gitg.gschema.xml.in:280
msgid ""
"Setting that determines how many lines of context (before and after) should "
"be shown when showing the diff of a commit."
msgstr "コミットの差分を表示するときに、変更の前後何行を表示するか決定する。"

#: data/org.gnome.gitg.gschema.xml.in:287
#: data/org.gnome.gitg.gschema.xml.in:306
msgid "Rendered Width of a Tab Character"
msgstr "タブ文字の表示文字幅"

#: data/org.gnome.gitg.gschema.xml.in:288
#: data/org.gnome.gitg.gschema.xml.in:307
msgid ""
"Setting that determines how much space a tab character should occupy when "
"showing the diff of a commit."
msgstr ""
"コミットの差分を表示するときに、タブ文字を何文字の半角空白で表示するかを決定"
"する。"

#: data/org.gnome.gitg.gschema.xml.in:298
msgid ""
"Setting that determines how many lines of context (before and after) should "
"be shown when showing the diff to be staged/unstaged in the commit area."
msgstr ""
"コミットの領域のステージング/ステージング解除の差分を表示するときに、変更の前"
"後何行を表示するかを決定する。"

#: gitg/commit/gitg-commit-dialog.vala:556 gitg/commit/gitg-commit.vala:1091
msgid "There are no changes to be committed"
msgstr "コミットする変更はありません"

#: gitg/commit/gitg-commit-dialog.vala:557 gitg/commit/gitg-commit.vala:1092
msgid "Use amend to change the commit message of the previous commit"
msgstr "直前のコミットのコミットメッサージを変更するためにアメンドを使う"

#: gitg/commit/gitg-commit.vala:113
msgctxt "Activity"
msgid "Commit"
msgstr "コミット"

#: gitg/commit/gitg-commit.vala:118
msgid "Create new commits and manage the staging area"
msgstr "新しくコミットを作成してステージング領域をマージする"

#: gitg/commit/gitg-commit.vala:207
msgid "_Stage selection"
msgstr "選択部分をステージに登録する(_S)"

#: gitg/commit/gitg-commit.vala:246
#, c-format
msgid "Failed to stage the removal of submodule “%s”"
msgstr "サブモジュール %s の削除に失敗"

#: gitg/commit/gitg-commit.vala:262
#, c-format
msgid "Failed to open the repository of submodule “%s” while trying to stage"
msgstr "ステージング中に、サブモジュールの %s リポジトリを開くのに失敗"

#: gitg/commit/gitg-commit.vala:277
#, c-format
msgid ""
"Failed to lookup the working directory commit of submodule “%s” while trying "
"to stage"
msgstr ""
"ステージング中に、サブモジュールの %s リポジトリのコミットの作業ディレクトリ"
"を検索するのに失敗"

#: gitg/commit/gitg-commit.vala:290
#, c-format
msgid "Failed to stage the submodule “%s”"
msgstr "サブモジュール %s のステージングに失敗"

#: gitg/commit/gitg-commit.vala:312
#, c-format
msgid "Failed to stage the removal of file “%s”"
msgstr "ファイル %s の削除に失敗"

#: gitg/commit/gitg-commit.vala:326
#, c-format
msgid "Failed to stage the file “%s”"
msgstr "ファイル %s のステージングに失敗"

#: gitg/commit/gitg-commit.vala:598
msgid "_Unstage selection"
msgstr "選択部分をステージから外す(_U)"

#: gitg/commit/gitg-commit.vala:664
#, c-format
msgid "Failed to unstage the removal of file “%s”"
msgstr "ファイル %s の削除のステージ解除に失敗しました"

#: gitg/commit/gitg-commit.vala:665
#, c-format
msgid "Failed to unstage the file “%s”"
msgstr "ファイル %s のステージング解除に失敗しました"

#: gitg/commit/gitg-commit.vala:672
#, c-format
msgid "Failed to unstage the removal of submodule “%s”"
msgstr "サブモジュール %s の削除のステージ解除に失敗しました"

#: gitg/commit/gitg-commit.vala:673
#, c-format
msgid "Failed to unstage the submodule “%s”"
msgstr "サブモジュール %s のステージング解除に失敗しました"

#. Populate staged items
#: gitg/commit/gitg-commit.vala:877
msgid "Staged"
msgstr "ステージ登録済み"

#: gitg/commit/gitg-commit.vala:885
msgid "No staged files"
msgstr "ステージ登録済みファイルなし"

#. Populate unstaged items
#: gitg/commit/gitg-commit.vala:908
msgid "Unstaged"
msgstr "ステージ未登録"

#: gitg/commit/gitg-commit.vala:916
msgid "No unstaged files"
msgstr "ステージ未登録ファイルなし"

#. Populate untracked items
#: gitg/commit/gitg-commit.vala:939
msgid "Untracked"
msgstr "管理対象外"

#: gitg/commit/gitg-commit.vala:943
msgid "No untracked files"
msgstr "管理対象外ファイルなし"

#: gitg/commit/gitg-commit.vala:968
msgid "Submodule"
msgstr "サブモジュール"

#: gitg/commit/gitg-commit.vala:972
msgid "No dirty submodules"
msgstr "ダーティなサブモジュールはありません"

#: gitg/commit/gitg-commit.vala:1121
msgid "Failed to commit"
msgstr "コミットに失敗しました"

# Translator's NOTE: !(...stage.pre_commit_hook(author))
#: gitg/commit/gitg-commit.vala:1137
msgid "Failed to pass pre-commit"
msgstr "プレコミットフックでエラーが発生しました"

#: gitg/commit/gitg-commit.vala:1302 gitg/commit/gitg-commit.vala:1452
msgid "Discard changes"
msgstr "変更を破棄"

#: gitg/commit/gitg-commit.vala:1303
msgid "Are you sure you want to permanently discard the selected changes?"
msgstr "あなたは本当に選択した変更を永久に破棄しますか?"

#: gitg/commit/gitg-commit.vala:1312 gitg/commit/gitg-commit.vala:1478
